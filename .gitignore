# Generated by Cargo
# will have compiled files and executables
/target/
**/*.rs.bk

# These are backup files generated by rustfmt
**/*.rs.bk

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# For executables, it's recommended to commit Cargo.lock
# Cargo.lock

# MSVC Windows builds of rustc generate these
*.pdb
*.exe
*.dll
*.exp
*.lib

# macOS
.DS_Store

# Editor files
.vscode/
*.swp
*.swo
*~
.idea/

# Project-specific
# If you want to keep Cargo.lock in the repo, uncomment the next line
# !Cargo.lock

# Output of any example binaries
/examples/**/*.exe

# Optional: if you use a build directory
/build/

